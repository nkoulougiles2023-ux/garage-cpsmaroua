DATABASE_URL="postgresql://user:password@localhost:5432/cps_maroua"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# ===== MTN MoMo API (Cameroon) =====
# Register at https://momodeveloper.mtn.com
# 1. Create account → Subscribe to Collection product → Get Subscription Key
# 2. Create API User (UUID v4) → Generate API Key
# 3. For production: Complete KYC → Use https://proxy.momoapi.mtn.com
MTN_MOMO_BASE_URL="https://sandbox.momodeveloper.mtn.com"
MTN_MOMO_SUBSCRIPTION_KEY="your-subscription-key"
MTN_MOMO_API_USER_ID="your-api-user-uuid"
MTN_MOMO_API_KEY="your-api-key"
MTN_MOMO_TARGET_ENV="sandbox"
MTN_MOMO_CALLBACK_URL="https://your-domain.com/api/webhooks/mtn-momo"

# ===== Orange Money API (Cameroon) =====
# Register at https://developer.orange.com
# 1. Create app → Subscribe to Orange Money Webpay
# 2. Get merchant key from Orange Money merchant account
# 3. Auth header = Base64(client_id:client_secret)
# 4. For production: Use https://api.orange.com/orange-money-webpay/cm/v1
ORANGE_MONEY_BASE_URL="https://api.orange.com/orange-money-webpay/dev/v1"
ORANGE_MONEY_MERCHANT_KEY="your-merchant-key"
ORANGE_MONEY_AUTH_HEADER="base64-encoded-client-credentials"
ORANGE_MONEY_NOTIF_URL="https://your-domain.com/api/webhooks/orange-money"
ORANGE_MONEY_RETURN_URL="https://your-domain.com/paiements?status=success"
ORANGE_MONEY_CANCEL_URL="https://your-domain.com/paiements?status=cancel"
